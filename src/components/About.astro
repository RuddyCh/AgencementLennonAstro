---
/**
 * About.astro — Section à propos / histoire
 * Layout 2 colonnes : image avec badge flottant + contenu
 * GSAP reveal depuis la gauche (image) et droite (texte)
 */

import { Image } from 'astro:assets';

const values = [
  {
    icon: `<path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/>`,
    text: 'Étude personnalisée et conseils d\'expert à chaque projet',
  },
  {
    icon: `<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>`,
    text: 'Fabrication artisanale et pose soignée par nos équipes',
  },
  {
    icon: `<rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/>`,
    text: 'Respect rigoureux des délais et du budget convenu',
  },
  {
    icon: `<path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/>`,
    text: 'Zone d\'intervention : Landivisiau, Brest, Morlaix, tout le Finistère',
  },
];
---

<section id="apropos" class="section bg-cream">
  <div class="container">
    <div class="grid lg:grid-cols-2 gap-16 xl:gap-24 items-center">

      <!-- Image + badge -->
      <div class="about-image-wrap reveal-left order-2 lg:order-1">
        <div class="relative">
          <Image
            src="/images/stevbg.jpg"
            alt="Extension de maison réalisée par Agencement Lennon — bardage anthracite et baies vitrées, Finistère"
            class="about-image-main w-full rounded-sm shadow-luxury-lg object-cover"
            style="aspect-ratio:4/5"
            width={600}
            height={750}
            quality={85}
            loading="lazy"
          />

          <!-- Badge flottant -->
          <div
            class="about-badge"
            aria-label="Fondé en 2021"
          >
            <span class="font-serif text-2xl font-bold leading-none" aria-hidden="true">2021</span>
            <span class="font-sans text-[0.6rem] tracking-widest uppercase mt-1 opacity-80">Fondé en</span>
          </div>

          <!-- Cadre décoratif décalé -->
          <div
            class="absolute -inset-4 border border-oak/20 rounded-sm -z-10 hidden lg:block"
            aria-hidden="true"
          ></div>
        </div>
      </div>

      <!-- Contenu texte -->
      <div class="order-1 lg:order-2">
        <span class="section-eyebrow reveal">Notre histoire</span>
        <h2 class="section-title reveal">
          La qualité<br><em>par passion</em>
        </h2>
        <div class="ornament-line reveal-clip mt-4 mb-8"></div>

        <div class="space-y-4 font-sans text-stone leading-relaxed mb-8 reveal">
          <p>
            Fondée en <strong class="text-navy">2021</strong> par <strong class="text-navy">Steven Lennon</strong>,
            Agencement Lennon est une entreprise de menuiserie basée à Landivisiau, au cœur du Finistère.
            La passion du bois et l'exigence du travail bien fait sont au cœur de chaque projet —
            du premier rendez-vous à la dernière finition.
          </p>
          <p>
            Nous intervenons auprès des particuliers et des professionnels pour des réalisations
            entièrement sur mesure. Pas d'intermédiaire, pas de sous-traitance : vous êtes suivi
            par l'artisan lui-même, avec rigueur et implication personnelle à chaque étape.
          </p>
        </div>

        <!-- Liste de valeurs -->
        <ul class="space-y-4 mb-10 stagger-parent" aria-label="Nos engagements">
          {values.map(value => (
            <li class="stagger-child flex items-start gap-3">
              <div class="flex-shrink-0 w-8 h-8 flex items-center justify-center
                          bg-oak/10 rounded-sm mt-0.5">
                <svg
                  class="w-4 h-4 text-oak"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  set:html={value.icon}
                />
              </div>
              <span class="font-sans text-sm text-stone leading-relaxed">{value.text}</span>
            </li>
          ))}
        </ul>

        <div class="reveal">
          <a href="#contact" class="btn-primary">
            Discutons de votre projet
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
