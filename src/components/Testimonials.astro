---
/**
 * Testimonials.astro — Avis clients Google (fetch au build)
 * ──────────────────────────────────────────────────────────
 * Récupère les avis via Google Places API à chaque `npm run build`.
 * Variables requises dans .env :
 *   GOOGLE_PLACES_API_KEY=...
 *   GOOGLE_PLACE_ID=...
 *
 * Limite Google : 5 avis max retournés par l'API (les plus pertinents).
 * Les avis statiques de secours s'affichent si l'API échoue.
 */

// ── Avis de secours (fallback si API indisponible au build) ──────────
const fallbackReviews = [
  {
    author:  'Marie-Laure B.',
    initial: 'M',
    rating:  5,
    date:    'Mars 2025',
    text:    "Steven a réalisé notre cuisine sur mesure avec un soin exceptionnel. Résultat bluffant, délais respectés, et un vrai professionnel à l'écoute. Je recommande sans hésitation !",
  },
  {
    author:  'Jean-Pierre L.',
    initial: 'J',
    rating:  5,
    date:    'Janvier 2025',
    text:    "Terrasse composite posée impeccablement. Travail soigné, matériaux de qualité. On a passé tout l'été dessus, aucun regret.",
  },
  {
    author:  'Émilie et Franck T.',
    initial: 'É',
    rating:  5,
    date:    'Novembre 2024',
    text:    "Dressing sur mesure parfaitement adapté à notre comble. Très belle finition, bois de qualité. Steven est à l'écoute et de bon conseil.",
  },
];

// ── Fetch Google Places API ──────────────────────────────────────────
const apiKey  = import.meta.env.GOOGLE_PLACES_API_KEY;
const placeId = import.meta.env.GOOGLE_PLACE_ID;

let reviews      = fallbackReviews;
let globalRating = 5.0;
let totalReviews = 12;
let apiOk        = false;
let reviewsUrl   = 'https://search.google.com/local/reviews?placeid=' + placeId;

function formatDate(timestamp) {
  return new Date(timestamp * 1000).toLocaleDateString('fr-FR', {
    month: 'long',
    year:  'numeric',
  });
}

if (apiKey && placeId) {
  try {
    const fields = 'name,rating,reviews,user_ratings_total,url';
    const url    = `https://maps.googleapis.com/maps/api/place/details/json`
                 + `?place_id=${placeId}`
                 + `&fields=${fields}`
                 + `&language=fr`
                 + `&reviews_sort=newest`
                 + `&key=${apiKey}`;

    const res  = await fetch(url);
    const data = await res.json();

    if (data.status === 'OK' && data.result) {
      globalRating = data.result.rating             ?? globalRating;
      totalReviews = data.result.user_ratings_total ?? totalReviews;
      if (data.result.url) reviewsUrl = data.result.url;

      if (Array.isArray(data.result.reviews) && data.result.reviews.length > 0) {
        reviews = data.result.reviews.map(r => ({
          author:   r.author_name,
          initial:  r.author_name.charAt(0).toUpperCase(),
          rating:   r.rating,
          date:     formatDate(r.time),
          text:     r.text,
          photoUrl: r.profile_photo_url || null,
        }));
        apiOk = true;
      }
    } else {
      console.warn(`[Testimonials] Google Places API status: ${data.status}`);
    }
  } catch (err) {
    console.error('[Testimonials] Erreur fetch Google Places:', err);
  }
} else {
  console.warn('[Testimonials] GOOGLE_PLACES_API_KEY ou GOOGLE_PLACE_ID manquant dans .env');
}

const StarIcon = `<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>`;
const leaveReviewUrl = `https://search.google.com/local/writereview?placeid=${placeId}`;
---

<section id="avis" class="section bg-cream" aria-labelledby="avis-title">
  <div class="container">

    <!-- En-tête -->
    <div class="mb-16">
      <span class="section-eyebrow reveal">Ce qu'ils disent</span>
      <h2 class="section-title reveal" id="avis-title">
        Avis de nos <em>clients</em>
      </h2>
      <div class="ornament-line reveal-clip mt-4 mb-6"></div>

      <!-- Note globale Google -->
      <div class="reveal flex flex-col sm:flex-row sm:items-center gap-6 mt-8">
        <div class="flex items-center gap-4 bg-white rounded-sm border border-cream-dark px-6 py-4 shadow-luxury w-fit">
          <svg width="28" height="28" viewBox="0 0 24 24" aria-label="Google" role="img">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          <div>
            <div class="flex items-center gap-2 mb-0.5">
              <span class="font-serif text-3xl font-bold text-navy leading-none">{globalRating.toFixed(1)}</span>
              <div class="flex text-oak" aria-label={`Note : ${globalRating} sur 5`}>
                {Array.from({ length: 5 }).map((_, i) => (
                  <span class={i < Math.round(globalRating) ? 'text-oak' : 'text-cream-dark'} set:html={StarIcon} />
                ))}
              </div>
            </div>
            <p class="font-sans text-xs text-stone">{totalReviews} avis Google vérifiés</p>
          </div>
        </div>

        <a href={leaveReviewUrl} target="_blank" rel="noopener noreferrer"
           class="btn-outline-dark text-xs" aria-label="Laisser un avis sur Google">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M12 20h9M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/>
          </svg>
          Laisser un avis
        </a>
      </div>

      {apiOk && (
        <p class="mt-3 font-sans text-xs text-stone/50 flex items-center gap-1.5">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
          Avis récupérés en direct depuis Google
        </p>
      )}
    </div>

    <!-- Grille d'avis -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 stagger-parent" role="list" aria-label="Avis clients">
      {reviews.map(review => (
        <article
          class="stagger-child bg-white rounded-sm border border-cream-dark p-7 flex flex-col gap-4 shadow-luxury hover:shadow-luxury-lg hover:-translate-y-0.5 transition-all duration-300 ease-luxury"
          role="listitem"
          itemscope
          itemtype="https://schema.org/Review"
        >
          <div class="flex gap-0.5 text-oak" aria-label={`${review.rating} étoiles sur 5`}
               itemprop="reviewRating" itemscope itemtype="https://schema.org/Rating">
            <meta itemprop="ratingValue" content={String(review.rating)} />
            <meta itemprop="bestRating"  content="5" />
            {Array.from({ length: 5 }).map((_, i) => (
              <span class={i < review.rating ? 'text-oak' : 'text-cream-dark'} set:html={StarIcon} />
            ))}
          </div>

          <blockquote class="flex-1" itemprop="reviewBody">
            <p class="font-sans text-sm text-stone leading-relaxed">"{review.text}"</p>
          </blockquote>

          <footer class="flex items-center justify-between border-t border-cream-dark pt-4">
            <div class="flex items-center gap-3">
              {review.photoUrl ? (
                <img src={review.photoUrl} alt={review.author} width="36" height="36"
                     class="w-9 h-9 rounded-full object-cover flex-shrink-0" loading="lazy" />
              ) : (
                <div class="w-9 h-9 rounded-full bg-navy flex items-center justify-center flex-shrink-0" aria-hidden="true">
                  <span class="font-serif text-sm text-oak-light font-semibold">{review.initial}</span>
                </div>
              )}
              <p class="font-sans text-sm font-medium text-navy" itemprop="author"
                 itemscope itemtype="https://schema.org/Person">
                <span itemprop="name">{review.author}</span>
              </p>
            </div>
            <time class="font-sans text-xs text-stone/60" itemprop="datePublished">{review.date}</time>
          </footer>
        </article>
      ))}
    </div>

    <!-- CTA voir tous les avis -->
    <div class="flex justify-center mt-10 reveal">
      <a href={reviewsUrl} target="_blank" rel="noopener noreferrer" class="btn-outline-dark"
         aria-label={`Voir tous les ${totalReviews} avis sur Google`}>
        <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        Voir tous nos avis Google ({totalReviews})
      </a>
    </div>

  </div>
</section>
