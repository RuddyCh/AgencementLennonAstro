---
/**
 * Footer.astro — Pied de page
 * 3 colonnes : marque, navigation, contact
 * Barre supérieure dorée, copyright + mentions légales
 */
---

<div class="footer-top-bar" aria-hidden="true"></div>

<footer class="bg-navy text-cream relative overflow-hidden" role="contentinfo">

  <!-- Texture grain -->
  <div class="absolute inset-0 bg-grain opacity-15 pointer-events-none" aria-hidden="true"></div>

  <div class="container relative">

    <!-- Grille principale -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-10 py-16 border-b border-white/10">

      <!-- Colonne Marque -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-flex items-center gap-3 mb-6 group" aria-label="Accueil Agencement Lennon">
          <img
            src="/images/logo-lennon.png"
            alt="Logo Agencement Lennon"
            class="w-10 h-10 object-contain"
            width="40" height="40"
            loading="lazy"
          />
          <div>
            <span class="block font-serif text-lg text-cream group-hover:text-oak-light transition-colors">
              Agencement Lennon
            </span>
            <span class="block text-[0.6rem] font-sans tracking-[0.25em] uppercase text-oak/70">
              La qualité par passion
            </span>
          </div>
        </a>
        <p class="font-sans text-sm text-cream/50 leading-relaxed max-w-xs">
          Menuiserie intérieure et extérieure sur mesure à Landivisiau, en Finistère.
          Artisan depuis 2021.
        </p>

        <!-- Réseaux sociaux -->
        <div class="flex gap-3 mt-6">
          <a
            href="https://www.facebook.com/AgencementLennon29"
            class="w-9 h-9 flex items-center justify-center bg-white/10 hover:bg-oak
                   rounded-sm transition-colors duration-200"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Page Facebook Agencement Lennon"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Colonne Navigation -->
      <div>
        <h4 class="font-sans text-xs tracking-[0.2em] uppercase text-cream/40 mb-5">Navigation</h4>
        <nav class="flex flex-col gap-3" aria-label="Navigation du pied de page">
          {[
            { href: '/#services',                                   label: 'Savoir-faire' },
            { href: '/services/cuisine-sur-mesure-finistere/',      label: 'Cuisine sur mesure' },
            { href: '/services/terrasse-bois-composite-finistere/', label: 'Terrasse bois & composite' },
            { href: '/services/dressing-rangements-sur-mesure/',    label: 'Dressing & rangements' },
            { href: '/services/bardage-exterieur-landivisiau/',     label: 'Bardage extérieur' },
            { href: '/#realisations',                               label: 'Réalisations' },
            { href: '/#avis',                                       label: 'Avis clients' },
            { href: '/#contact',                                    label: 'Contact & Devis' },
          ].map(({ href, label }) => (
            <a
              href={href}
              class="font-sans text-sm text-cream/60 hover:text-cream transition-colors duration-200
                     flex items-center gap-2 group"
            >
              <span class="w-4 h-px bg-oak/40 group-hover:w-6 group-hover:bg-oak
                           transition-all duration-300" aria-hidden="true"></span>
              {label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Colonne Contact -->
      <div>
        <h4 class="font-sans text-xs tracking-[0.2em] uppercase text-cream/40 mb-5">Nous retrouver</h4>
        <address class="not-italic space-y-3">
          <div class="flex items-start gap-3">
            <svg class="w-4 h-4 text-oak flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <p class="font-sans text-sm text-cream/60 leading-relaxed">
              11 rue des Cols-Verts<br>
              29400 Landivisiau, Bretagne
            </p>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-4 h-4 text-oak flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <a href="tel:+33767426234" class="font-sans text-sm text-oak-light hover:text-cream transition-colors">
              07 67 42 62 34
            </a>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-4 h-4 text-oak flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            <a href="mailto:contact@agencementlennon.fr" class="font-sans text-sm text-cream/60 hover:text-cream transition-colors">
              contact@agencementlennon.fr
            </a>
          </div>
        </address>

        <div class="mt-6">
          <a href="/#contact" class="btn-primary text-xs px-5 py-2.5">
            Demander un devis gratuit
          </a>
        </div>
      </div>

    </div>

    <!-- Barre de copyright -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 py-6">
      <p class="font-sans text-xs text-cream/30">
        © {new Date().getFullYear()} Agencement Lennon — Landivisiau, Finistère
      </p>
      <nav class="flex flex-wrap gap-4 justify-center" aria-label="Liens légaux">
        <a href="/mentions-legales" class="font-sans text-xs text-cream/30 hover:text-cream/60 transition-colors">
          Mentions légales
        </a>
        <span class="text-cream/20" aria-hidden="true">·</span>
        <a href="/politique-cookies" class="font-sans text-xs text-cream/30 hover:text-cream/60 transition-colors">
          Politique cookies
        </a>
        <span class="text-cream/20" aria-hidden="true">·</span>
        <button
          id="manageCookies"
          class="font-sans text-xs text-cream/30 hover:text-cream/60 transition-colors cursor-pointer bg-transparent border-none p-0"
        >
          Gérer les cookies
        </button>
      </nav>
    </div>

  </div>
</footer>
