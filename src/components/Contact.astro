---
/**
 * Contact.astro — Section contact
 * Formulaire Formspree + coordonnées + carte Google Maps
 * Gestion async du formulaire avec états loading/success/error
 */
---

<section id="contact" class="section bg-cream-warm">
  <div class="container">

    <!-- En-tête -->
    <div class="mb-12">
      <span class="section-eyebrow reveal">Prise de contact</span>
      <h2 class="section-title reveal">Contactez-<em>nous</em></h2>
      <div class="ornament-line reveal-clip mt-4 mb-6"></div>
      <p class="section-subtitle reveal">
        Un projet en tête ? Parlons-en. Devis gratuit et sans engagement, réponse sous 48h.
      </p>
    </div>

    <div class="grid lg:grid-cols-5 gap-12 xl:gap-16">

      <!-- Coordonnées (2 colonnes) -->
      <div class="lg:col-span-2 reveal-left">
        <div class="bg-navy rounded-sm p-8 text-cream h-full relative overflow-hidden">

          <!-- Texture -->
          <div class="absolute inset-0 bg-grain opacity-20 pointer-events-none" aria-hidden="true"></div>
          <!-- Ligne déco gauche -->
          <div class="absolute left-0 top-0 bottom-0 w-1 bg-oak" aria-hidden="true"></div>

          <div class="relative">
            <p class="font-serif text-xl text-cream mb-1">Agencement Lennon</p>
            <p class="font-sans text-sm text-cream/50 mb-8">Artisan menuisier — Landivisiau, Finistère</p>

            <!-- Contact items -->
            <div class="space-y-5" role="list">

              <div class="flex items-start gap-4" role="listitem">
                <div class="w-9 h-9 flex-shrink-0 flex items-center justify-center
                            bg-white/10 rounded-sm mt-0.5">
                  <svg class="w-4 h-4 text-oak" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-sans text-cream/40 tracking-widest uppercase mb-1">Téléphone</p>
                  <a href="tel:+33767426234" class="font-sans text-sm text-cream hover:text-oak-light transition-colors">
                    07 67 42 62 34
                  </a>
                </div>
              </div>

              <div class="flex items-start gap-4" role="listitem">
                <div class="w-9 h-9 flex-shrink-0 flex items-center justify-center
                            bg-white/10 rounded-sm mt-0.5">
                  <svg class="w-4 h-4 text-oak" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-sans text-cream/40 tracking-widest uppercase mb-1">Email</p>
                  <a href="mailto:contact@agencementlennon.fr" class="font-sans text-sm text-cream hover:text-oak-light transition-colors break-all">
                    contact@agencementlennon.fr
                  </a>
                </div>
              </div>

              <div class="flex items-start gap-4" role="listitem">
                <div class="w-9 h-9 flex-shrink-0 flex items-center justify-center
                            bg-white/10 rounded-sm mt-0.5">
                  <svg class="w-4 h-4 text-oak" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-sans text-cream/40 tracking-widest uppercase mb-1">Adresse</p>
                  <address class="font-sans text-sm text-cream not-italic leading-relaxed">
                    11 rue des Cols-Verts<br>
                    29400 Landivisiau
                  </address>
                </div>
              </div>

            </div>

            <!-- Horaires -->
            <div class="mt-8 pt-6 border-t border-white/10">
              <p class="text-xs font-sans text-cream/40 tracking-widest uppercase mb-3">Disponibilité</p>
              <p class="font-sans text-sm text-cream/70 leading-relaxed">
                Du lundi au vendredi<br>
                Sur rendez-vous · Zone Finistère
              </p>
            </div>

            <!-- Facebook -->
            <div class="mt-6">
              <a
                href="https://www.facebook.com/AgencementLennon29"
                class="inline-flex items-center gap-2.5 text-xs font-sans text-cream/60
                       hover:text-cream transition-colors duration-200"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Page Facebook d'Agencement Lennon"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
                Suivre sur Facebook
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Formulaire (3 colonnes) -->
      <div class="lg:col-span-3 reveal">
        <form
          id="contactForm"
          action="https://formspree.io/f/mpqkkkbp"
          method="POST"
          novalidate
          class="space-y-5"
          aria-label="Formulaire de demande de devis"
        >
          <!-- Nom -->
          <div class="form-group">
            <label for="contact-name" class="form-label">Votre nom *</label>
            <input
              type="text"
              id="contact-name"
              name="name"
              autocomplete="name"
              required
              placeholder="Jean Dupont"
              class="form-input"
            />
          </div>

          <!-- Email + Téléphone -->
          <div class="grid sm:grid-cols-2 gap-5">
            <div class="form-group">
              <label for="contact-email" class="form-label">Email *</label>
              <input
                type="email"
                id="contact-email"
                name="email"
                autocomplete="email"
                required
                placeholder="jean@email.fr"
                class="form-input"
              />
            </div>
            <div class="form-group">
              <label for="contact-phone" class="form-label">Téléphone</label>
              <input
                type="tel"
                id="contact-phone"
                name="phone"
                autocomplete="tel"
                placeholder="06 12 34 56 78"
                class="form-input"
              />
            </div>
          </div>

          <!-- Type de projet -->
          <div class="form-group">
            <label for="contact-subject" class="form-label">Type de projet</label>
            <select id="contact-subject" name="subject" class="form-select">
              <option value="">— Sélectionnez votre projet —</option>
              <option value="cuisine">Cuisine sur mesure</option>
              <option value="dressing">Dressing / Rangements</option>
              <option value="terrasse">Terrasse / Extérieur</option>
              <option value="bardage">Bardage / Extension</option>
              <option value="parquet">Parquet / Sol</option>
              <option value="autre">Autre projet</option>
            </select>
          </div>

          <!-- Message -->
          <div class="form-group">
            <label for="contact-message" class="form-label">Décrivez votre projet *</label>
            <textarea
              id="contact-message"
              name="message"
              rows="5"
              required
              placeholder="Ex : Je souhaite une cuisine en L de 8m², style moderne, avec îlot central…"
              class="form-textarea"
            ></textarea>
          </div>

          <!-- Footer form -->
          <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 pt-2">
            <button
              type="submit"
              id="formSubmit"
              class="btn-primary text-sm px-8 py-4 w-full sm:w-auto"
            >
              <span id="submitText">Envoyer ma demande</span>
              <span id="submitLoading" hidden class="flex items-center gap-2">
                <svg class="animate-spin w-4 h-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
                </svg>
                Envoi en cours…
              </span>
            </button>
            <p class="font-sans text-xs text-stone">
              * Champs obligatoires. Données utilisées uniquement pour votre demande.
            </p>
          </div>

          <!-- Messages de retour -->
          <div id="formSuccess" role="alert" hidden
            class="flex items-center gap-3 p-4 bg-green-50 border border-green-200 rounded-sm text-green-800 text-sm font-sans">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path d="M20 6 9 17l-5-5"/>
            </svg>
            Message envoyé avec succès ! Nous vous répondrons sous 48h.
          </div>
          <div id="formError" role="alert" hidden
            class="flex items-center gap-3 p-4 bg-red-50 border border-red-200 rounded-sm text-red-800 text-sm font-sans">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/>
            </svg>
            Une erreur s'est produite. Contactez-nous directement au 07 67 42 62 34.
          </div>

        </form>
      </div>

    </div>

    <!-- Carte Google Maps — façade RGPD : chargement uniquement au clic -->
    <div class="mt-16 reveal">
      <div
        id="map-facade"
        class="map-facade w-full h-72 sm:h-96 rounded-sm shadow-luxury overflow-hidden relative
               bg-navy/5 border border-navy/10 flex flex-col items-center justify-center gap-4
               cursor-pointer group"
        role="button"
        tabindex="0"
        aria-label="Afficher la carte Google Maps — Agencement Lennon, Landivisiau"
      >
        <!-- Fond décoratif grille cartographique -->
        <div class="absolute inset-0 opacity-10"
             style="background-image: linear-gradient(var(--navy) 1px, transparent 1px), linear-gradient(90deg, var(--navy) 1px, transparent 1px); background-size: 40px 40px;"
             aria-hidden="true"></div>

        <!-- Icône carte -->
        <div class="relative w-14 h-14 flex items-center justify-center bg-navy rounded-full
                    group-hover:bg-oak transition-colors duration-300">
          <svg class="w-7 h-7 text-cream" viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="1.5" aria-hidden="true">
            <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
        </div>

        <!-- Texte -->
        <div class="relative text-center px-4">
          <p class="font-serif text-navy text-lg mb-1">Agencement Lennon</p>
          <p class="font-sans text-sm text-stone mb-3">11 rue des Cols-Verts · 29400 Landivisiau</p>
          <span class="inline-flex items-center gap-2 text-xs font-sans text-oak border border-oak/40
                       px-4 py-2 rounded-sm group-hover:bg-oak group-hover:text-white
                       transition-colors duration-300">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" aria-hidden="true">
              <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4M10 17l5-5-5-5M13 12H3"/>
            </svg>
            Cliquer pour afficher la carte
          </span>
          <p class="font-sans text-[0.65rem] text-stone/60 mt-2">
            En cliquant, vous acceptez le chargement de Google Maps (cookies tiers).
          </p>
        </div>
      </div>

      <!-- L'iframe est injecté dynamiquement au clic -->
      <iframe
        id="map-iframe"
        class="w-full h-72 sm:h-96 rounded-sm border-0 shadow-luxury hidden"
        title="Agencement Lennon — 11 rue des Cols-Verts, 29400 Landivisiau"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        data-src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d5285.751012811356!2d-4.062583822306529!3d48.51645117128783!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x481151883fcbcad7%3A0xc2a7b09a0cd35c9b!2sAgencement%20Lennon!5e0!3m2!1sfr!2sfr!4v1756772877848!5m2!1sfr!2sfr"
        allowfullscreen
      ></iframe>
    </div>

  </div>
</section>

<script>
  // ─────────────────────────────────────────────────────────────
  // ⚠️  FORMSPREE — ACTION REQUISE
  // ─────────────────────────────────────────────────────────────
  // 1. Créez un compte sur https://formspree.io (gratuit)
  // 2. Créez un nouveau formulaire et copiez l'ID généré
  // 3. Remplacez "VOTRE_ID_FORMSPREE" ci-dessous par votre ID
  //    Exemple : action="https://formspree.io/f/xpzgkrva"
  // ─────────────────────────────────────────────────────────────

  // ── Formulaire de contact (async Formspree) ──────────────────
  const form        = document.getElementById('contactForm') as HTMLFormElement;
  const submitBtn   = document.getElementById('formSubmit') as HTMLButtonElement;
  const submitText  = document.getElementById('submitText') as HTMLSpanElement;
  const submitLoad  = document.getElementById('submitLoading') as HTMLSpanElement;
  const successMsg  = document.getElementById('formSuccess') as HTMLDivElement;
  const errorMsg    = document.getElementById('formError') as HTMLDivElement;

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      submitBtn.disabled = true;
      submitText.hidden  = true;
      submitLoad.hidden  = false;
      successMsg.hidden  = true;
      errorMsg.hidden    = true;

      try {
        const res = await fetch(form.action, {
          method:  'POST',
          body:    new FormData(form),
          headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          form.reset();
          successMsg.hidden = false;
          successMsg.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        } else {
          throw new Error('Server error');
        }
      } catch {
        errorMsg.hidden = false;
      } finally {
        submitBtn.disabled = false;
        submitText.hidden  = false;
        submitLoad.hidden  = true;
      }
    });
  }

  // ── Façade RGPD Google Maps — chargement au clic ─────────────
  const mapFacade = document.getElementById('map-facade');
  const mapIframe = document.getElementById('map-iframe') as HTMLIFrameElement;

  const loadMap = () => {
    if (!mapIframe || !mapFacade) return;
    const src = mapIframe.getAttribute('data-src');
    if (src) {
      mapIframe.src = src;
      mapIframe.classList.remove('hidden');
      mapFacade.classList.add('hidden');
    }
  };

  mapFacade?.addEventListener('click', loadMap);
  mapFacade?.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      loadMap();
    }
  });
</script>
