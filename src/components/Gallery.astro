---
/**
 * Gallery.astro — Section réalisations
 * Grille masonry-like, lightbox natif avec navigation clavier
 * GSAP stagger reveal + hover parallaxe
 * Images optimisées via Astro Image (WebP auto, srcset)
 */

import { Image } from 'astro:assets';

import imgCuisineBicolore    from '../assets/images/cuisine-bicolore-anthracite-chene-landivisiau.jpeg';
import imgTerrasseAerienne   from '../assets/images/terrasse-composite-bicolore-vue-aerienne.jpeg';
import imgCuisineChene       from '../assets/images/cuisine-chene-naturel-hotte-noire-landivisiau.jpg';
import imgExtensionBardage   from '../assets/images/extension-bardage-anthracite-baies-vitrees-finistere.jpeg';
import imgCuisineBlanche     from '../assets/images/cuisine-blanche-plan-travail-bois-ilot-finistere.jpg';
import imgSousEscalier       from '../assets/images/amenagement-sous-escalier-banquette-rangements.jpg';
import imgTerrasseJardin     from '../assets/images/terrasse-composite-exterieur-jardin-bretagne.jpeg';
import imgTerrassePlongeante from '../assets/images/vue-plongeante-terrasse-composite-gris-beige.jpeg';

const projects = [
  {
    img:     imgCuisineBicolore,
    alt:     'Cuisine bicolore anthracite et chêne sur mesure — Menuiserie Landivisiau, Finistère',
    caption: 'Cuisine bicolore anthracite & chêne',
    loading: 'eager' as const,
    featured: true,
  },
  {
    img:     imgTerrasseAerienne,
    alt:     'Terrasse bois composite bicolore vue aérienne — Agencement Lennon Finistère',
    caption: 'Terrasse composite bicolore',
    loading: 'lazy' as const,
    featured: false,
  },
  {
    img:     imgCuisineChene,
    alt:     'Cuisine en chêne naturel avec hotte noire — Menuiserie sur mesure Landivisiau',
    caption: 'Cuisine chêne naturel',
    loading: 'lazy' as const,
    featured: false,
  },
  {
    img:     imgExtensionBardage,
    alt:     'Extension de maison bardage anthracite grandes baies vitrées — Agencement Lennon',
    caption: 'Extension & bardage anthracite',
    loading: 'lazy' as const,
    featured: false,
  },
  {
    img:     imgCuisineBlanche,
    alt:     'Cuisine blanche avec plan de travail bois et îlot — Menuiserie Finistère',
    caption: 'Cuisine blanche & bois naturel',
    loading: 'lazy' as const,
    featured: false,
  },
  {
    img:     imgSousEscalier,
    alt:     'Aménagement sur mesure sous escalier banquette et rangements — Landivisiau',
    caption: 'Aménagement sous-escalier',
    loading: 'lazy' as const,
    featured: false,
  },
  {
    img:     imgTerrasseJardin,
    alt:     'Terrasse composite bois depuis le jardin — Agencement Lennon Bretagne',
    caption: 'Terrasse extérieure composite',
    loading: 'lazy' as const,
    featured: false,
  },
  {
    img:     imgTerrassePlongeante,
    alt:     'Vue plongeante terrasse composite bicolore gris et beige — Finistère',
    caption: 'Vue plongeante · Terrasse composite',
    loading: 'lazy' as const,
    featured: false,
  },
];
---

<section id="realisations" class="section bg-cream-warm">
  <div class="container">

    <!-- En-tête -->
    <div class="mb-12">
      <span class="section-eyebrow reveal">Portfolio</span>
      <h2 class="section-title reveal">Nos <em>réalisations</em></h2>
      <div class="ornament-line reveal-clip mt-4 mb-6"></div>
      <p class="section-subtitle reveal">
        Chaque chantier est une signature. Voici quelques-unes de nos réalisations récentes
        en Finistère — cuisines, terrasses, extensions.
      </p>
    </div>

    <!-- Grille galerie -->
    <div
      class="gallery-grid grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 stagger-parent"
      role="list"
      aria-label="Galerie de réalisations"
    >
      {projects.map((project, index) => (
        <a
          href={project.img.src}
          class={`gallery-item stagger-child rounded-sm overflow-hidden ${
            index === 0 ? 'md:col-span-2 md:row-span-2' : ''
          }`}
          aria-label={`Voir en grand : ${project.caption}`}
          role="listitem"
          data-lightbox
          data-src={project.img.src}
          data-alt={project.alt}
        >
          <Image
            src={project.img}
            alt={project.alt}
            loading={project.loading}
            width={index === 0 ? 800 : 600}
            height={index === 0 ? 600 : 450}
            quality={82}
            class="w-full h-full object-cover"
            style={index === 0 ? 'aspect-ratio:auto' : 'aspect-ratio:4/3'}
          />
          <div class="gallery-caption">
            <span class="font-sans text-sm">{project.caption}</span>
          </div>
          <!-- Icône loupe -->
          <div class="absolute top-3 right-3 w-8 h-8 bg-white/20 backdrop-blur-sm rounded-full
                      flex items-center justify-center opacity-0 group-hover:opacity-100
                      transition-opacity duration-200" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
              <path d="M11 8v6M8 11h6"/>
            </svg>
          </div>
        </a>
      ))}
    </div>

    <!-- CTA vers Facebook -->
    <div class="flex justify-center mt-10 reveal">
      <a
        href="https://www.facebook.com/AgencementLennon29"
        class="btn-outline-dark"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Voir tous nos projets sur notre page Facebook"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
        </svg>
        Voir tous nos projets sur Facebook
      </a>
    </div>

  </div>
</section>

<!-- LIGHTBOX -->
<div
  id="lightbox"
  class="lightbox-overlay"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
  aria-label="Visionneuse d'images"
>
  <div class="lightbox-img-wrap relative">
    <img id="lightbox-img" src="" alt="" class="max-w-[90vw] max-h-[85vh] object-contain rounded-sm shadow-luxury-lg" />

    <!-- Légende -->
    <p id="lightbox-caption" class="absolute -bottom-8 left-0 right-0 text-center
                                     text-sm font-sans text-cream/60"></p>

    <!-- Fermer -->
    <button class="lightbox-close-btn" id="lightbox-close" aria-label="Fermer la visionneuse">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>

    <!-- Navigation -->
    <button class="lightbox-btn -left-16" id="lightbox-prev" aria-label="Image précédente">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="m15 18-6-6 6-6"/>
      </svg>
    </button>
    <button class="lightbox-btn -right-16" id="lightbox-next" aria-label="Image suivante">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="m9 18 6-6-6-6"/>
      </svg>
    </button>
  </div>
</div>

<script>
  // ── Lightbox avec Focus Trap (accessibilité WCAG 2.1) ─────────
  const galleryLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-lightbox]'));
  const lightbox     = document.getElementById('lightbox');
  const lightboxImg  = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxCap  = document.getElementById('lightbox-caption');
  const closeBtn     = document.getElementById('lightbox-close');
  const prevBtn      = document.getElementById('lightbox-prev');
  const nextBtn      = document.getElementById('lightbox-next');

  if (lightbox && galleryLinks.length && lightboxImg) {
    const images = galleryLinks.map(link => ({
      src: link.getAttribute('data-src') || link.href,
      alt: link.getAttribute('data-alt') || '',
      cap: link.querySelector('.gallery-caption span')?.textContent || '',
    }));
    let currentIndex = 0;

    // ── Focus Trap : garder le focus à l'intérieur de la lightbox ──
    const getFocusableEls = () =>
      Array.from(
        lightbox.querySelectorAll<HTMLElement>(
          'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
        )
      ).filter(el => !el.hasAttribute('disabled'));

    const trapFocus = (e: KeyboardEvent) => {
      if (!lightbox.classList.contains('open') || e.key !== 'Tab') return;
      const focusable = getFocusableEls();
      const first     = focusable[0];
      const last      = focusable[focusable.length - 1];

      if (e.shiftKey) {
        // Shift+Tab : si on est sur le premier, aller au dernier
        if (document.activeElement === first) {
          e.preventDefault();
          last.focus();
        }
      } else {
        // Tab : si on est sur le dernier, revenir au premier
        if (document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    };

    const showImage = (index: number) => {
      currentIndex = (index + images.length) % images.length;
      lightboxImg.src = images[currentIndex].src;
      lightboxImg.alt = images[currentIndex].alt;
      if (lightboxCap) lightboxCap.textContent = images[currentIndex].cap;

      // Mettre à jour les aria-labels de navigation
      if (prevBtn) prevBtn.setAttribute('aria-label', `Image précédente : ${images[(currentIndex - 1 + images.length) % images.length].cap}`);
      if (nextBtn) nextBtn.setAttribute('aria-label', `Image suivante : ${images[(currentIndex + 1) % images.length].cap}`);

      lightbox.classList.add('open');
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';

      // Focus sur le bouton fermer après transition CSS
      setTimeout(() => closeBtn?.focus(), 50);
    };

    const closeLightbox = () => {
      lightbox.classList.remove('open');
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      // Remettre le focus sur l'élément déclencheur
      galleryLinks[currentIndex]?.focus();
    };

    galleryLinks.forEach((link, i) => {
      link.addEventListener('click', e => { e.preventDefault(); showImage(i); });
    });

    closeBtn?.addEventListener('click', closeLightbox);
    prevBtn?.addEventListener('click', () => showImage(currentIndex - 1));
    nextBtn?.addEventListener('click', () => showImage(currentIndex + 1));

    lightbox.addEventListener('click', e => {
      if (e.target === lightbox) closeLightbox();
    });

    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (!lightbox.classList.contains('open')) return;
      if (e.key === 'Escape')     { closeLightbox(); return; }
      if (e.key === 'ArrowRight') { showImage(currentIndex + 1); return; }
      if (e.key === 'ArrowLeft')  { showImage(currentIndex - 1); return; }
      trapFocus(e);
    });
  }
</script>
