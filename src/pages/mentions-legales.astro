---
/**
 * mentions-legales.astro — Page mentions légales
 */

import Layout  from '../layouts/Layout.astro';
import Navbar  from '../components/Navbar.astro';
import Footer  from '../components/Footer.astro';
---

<Layout
  title="Mentions légales | Agencement Lennon — Landivisiau"
  description="Mentions légales et politique de confidentialité d'Agencement Lennon, menuiserie sur mesure à Landivisiau (Finistère)."
  canonical="https://www.agencementlennon.fr/mentions-legales"
>
  <Navbar />

  <main class="legal-page" id="contenu">
    <div class="container pt-28 pb-20">

      <h1 class="font-serif text-h1 text-navy mb-10 pb-6 border-b border-cream-dark">
        Mentions légales
      </h1>

      <div class="max-w-prose-xl space-y-10">

        <section>
          <h2 class="font-serif text-xl text-navy mb-4">Éditeur du site</h2>
          <div class="font-sans text-stone leading-relaxed space-y-1">
            <p><strong class="text-navy">Agencement Lennon</strong></p>
            <p>11 rue des Cols-Verts, 29400 Landivisiau, France</p>
            <p>
              Téléphone :
              <a href="tel:+33767426234" class="text-oak hover:text-oak-dark transition-colors">
                07 67 42 62 34
              </a>
            </p>
            <p>
              Email :
              <a href="mailto:contact@agencementlennon.fr" class="text-oak hover:text-oak-dark transition-colors">
                contact@agencementlennon.fr
              </a>
            </p>
            <p>Directeur de publication : Steven Lennon</p>
          </div>
        </section>

        <section>
          <h2 class="font-serif text-xl text-navy mb-4">Hébergement</h2>
          <p class="font-sans text-stone leading-relaxed">
            Ce site est hébergé par [Nom de l'hébergeur], [adresse], [téléphone].
            <em class="text-xs text-stone/60 block mt-1">⚠ À compléter avant mise en ligne</em>
          </p>
        </section>

        <section>
          <h2 class="font-serif text-xl text-navy mb-4">Propriété intellectuelle</h2>
          <p class="font-sans text-stone leading-relaxed">
            Tous les contenus présents sur ce site (textes, images, graphismes, logo, icônes)
            sont la propriété exclusive d'Agencement Lennon, sauf mention contraire.
            Toute reproduction, distribution, modification ou retransmission, même partielle,
            est strictement interdite sans accord écrit de l'entreprise.
          </p>
        </section>

        <section>
          <h2 class="font-serif text-xl text-navy mb-4">Protection des données personnelles</h2>
          <p class="font-sans text-stone leading-relaxed">
            Les informations recueillies via le formulaire de contact (nom, email, message)
            sont utilisées uniquement pour répondre à vos demandes. Conformément au Règlement
            Général sur la Protection des Données (RGPD), vous disposez d'un droit d'accès,
            de rectification et de suppression de vos données en nous contactant à :
            <a href="mailto:contact@agencementlennon.fr" class="text-oak hover:text-oak-dark">
              contact@agencementlennon.fr
            </a>.
          </p>
        </section>

        <section>
          <h2 class="font-serif text-xl text-navy mb-4">Responsabilité</h2>
          <p class="font-sans text-stone leading-relaxed">
            Agencement Lennon ne saurait être tenu responsable des erreurs rencontrées sur le site,
            problèmes techniques, interprétation des informations publiées et conséquences de
            leur utilisation.
          </p>
        </section>

        <div class="pt-6">
          <a href="/" class="btn-outline-dark text-sm">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="m15 18-6-6 6-6"/>
            </svg>
            Retour à l'accueil
          </a>
        </div>

      </div>
    </div>
  </main>

  <Footer />
</Layout>
