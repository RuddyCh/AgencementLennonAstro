---
/**
 * /services/terrasse-bois-composite-finistere/
 * Cibles SEO : "terrasse composite Finistère", "pose terrasse bois Landivisiau",
 *              "terrasse bois composite Bretagne", "terrasse bois 29"
 */
import Layout  from '../../layouts/Layout.astro';
import Navbar  from '../../components/Navbar.astro';
import Footer  from '../../components/Footer.astro';
import CookieBanner from '../../components/CookieBanner.astro';
import WhatsAppFAB   from '../../components/WhatsAppFAB.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import ServiceFAQ  from '../../components/ServiceFAQ.astro';

import serviceData from '../../../content/services/terrasse.json';

const serviceJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Terrasse bois et composite en Finistère",
  "description": "Conception et pose de terrasses bois massif et composite en Finistère. Matériaux adaptés au climat breton, fabrication artisanale et pose soignée par Agencement Lennon à Landivisiau.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Agencement Lennon",
    "telephone": "+33767426234",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "11 rue des Cols-Verts",
      "addressLocality": "Landivisiau",
      "postalCode": "29400",
      "addressCountry": "FR"
    }
  },
  "areaServed": [
    { "@type": "City", "name": "Landivisiau" },
    { "@type": "City", "name": "Brest" },
    { "@type": "City", "name": "Morlaix" },
    { "@type": "AdministrativeArea", "name": "Finistère" }
  ]
});

const faq = [
  {
    q: "Bois ou composite : que choisir pour le climat breton ?",
    a: "Le composite est idéal pour la Bretagne : imputrescible, anti-dérapant mouillé, sans entretien annuel. Le bois massif (pin traité, douglas, teck) offre un aspect plus naturel mais demande un entretien régulier (lasure, huilage). Nous vous conseillons selon votre usage et votre budget.",
  },
  {
    q: "Faut-il un permis de construire pour une terrasse ?",
    a: "Généralement non pour une terrasse de plain-pied. Au-delà de 20 m² ou si la terrasse est surélevée, une déclaration préalable peut être nécessaire. Nous vous guidons sur les démarches selon votre situation.",
  },
  {
    q: "Quelle est la durée de vie d'une terrasse composite ?",
    a: "Un composite de qualité a une durée de vie de 25 à 30 ans avec très peu d'entretien (un nettoyage annuel suffit). Nous travaillons avec des fabricants garantissant leurs produits 10 à 25 ans.",
  },
  {
    q: "Posez-vous sur tous types de support ?",
    a: "Oui : dalle béton existante, plots réglables sur terre, lambourdes sur ossature bois. Le type de support conditionne la solution technique — nous l'évaluons lors de la visite.",
  },
  {
    q: "Quelle est la surface minimale pour un chantier ?",
    a: "Nous intervenons dès 15 m². La plupart de nos chantiers vont de 20 à 80 m².",
  },
];
---

<Layout
  title="Terrasse bois & composite Finistère — Pose Landivisiau | Agencement Lennon"
  description="Pose de terrasses bois et composite en Finistère. Matériaux résistants au climat breton, finitions soignées. Artisan Landivisiau. Devis gratuit."
  canonical="https://www.agencementlennon.fr/services/terrasse-bois-composite-finistere/"
  isHome={false}
>
  <script type="application/ld+json" set:html={serviceJsonLd} slot="head" />
  <Navbar />

  <main id="contenu">

    <!-- HERO -->
    <!-- ── HERO PAGE SERVICE ───────────────────────────────────── -->
    <ServiceHero
      eyebrow="Aménagement extérieur"
      titleLine1="Terrasse bois & composite"
      titleLine2="en Finistère"
      subtitle={serviceData.heroSubtitle}
      breadcrumb="Terrasse bois & composite"
    />

    <!-- IMAGES PLACEHOLDER -->
    <div class="bg-cream-warm">
      <div class="container py-0">
        <div class="grid lg:grid-cols-2 gap-0 rounded-sm overflow-hidden shadow-luxury-lg -mt-8 lg:-mt-12 relative z-10">
          <div class="aspect-[4/3] bg-navy/10 min-h-[280px] overflow-hidden">
            {serviceData.photo1 ? (
              <img src={serviceData.photo1} alt={serviceData.photo1Alt} class="w-full h-full object-cover" loading="eager" />
            ) : (
              <div class="w-full h-full flex items-center justify-center p-8">
                <div class="text-center">
                  <svg class="w-12 h-12 text-navy/20 mx-auto mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect width="18" height="18" x="3" y="3" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                  <p class="font-sans text-xs text-navy/30">Photo à ajouter via l'admin Tina<br>Pages Services → Terrasse → Photo principale</p>
                </div>
              </div>
            )}
          </div>
          <div class="aspect-[4/3] bg-cream-dark min-h-[280px] overflow-hidden">
            {serviceData.photo2 ? (
              <img src={serviceData.photo2} alt={serviceData.photo2Alt} class="w-full h-full object-cover" loading="lazy" />
            ) : (
              <div class="w-full h-full flex items-center justify-center p-8">
                <div class="text-center">
                  <svg class="w-12 h-12 text-navy/20 mx-auto mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect width="18" height="18" x="3" y="3" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                  <p class="font-sans text-xs text-navy/30">2ème photo à ajouter via l'admin Tina<br>Pages Services → Terrasse → Photo secondaire</p>
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>

    <!-- CONTENU -->
    <section class="section bg-cream-warm">
      <div class="container">
        <div class="grid lg:grid-cols-3 gap-16">
          <div class="lg:col-span-2">
            <h2 class="font-serif text-h2 text-navy mb-6 reveal">
              Bois ou composite :<br><em>le bon choix pour la Bretagne</em>
            </h2>
            <div class="ornament-line reveal-clip mb-8"></div>
            <div class="space-y-5 font-sans text-stone leading-relaxed reveal">
              <p>{serviceData.intro1}</p>
              <p>{serviceData.intro2}</p>
              <p>{serviceData.intro3}</p>
            </div>

            <!-- Comparatif bois vs composite -->
            <div class="mt-12 reveal">
              <h3 class="font-serif text-h3 text-navy mb-6">Bois massif vs Composite — comparatif</h3>
              <div class="overflow-x-auto rounded-sm border border-cream-dark">
                <table class="w-full font-sans text-sm">
                  <thead>
                    <tr class="bg-navy text-cream">
                      <th class="text-left px-5 py-3 font-medium text-xs tracking-widest uppercase">Critère</th>
                      <th class="text-center px-5 py-3 font-medium text-xs tracking-widest uppercase">Bois massif</th>
                      <th class="text-center px-5 py-3 font-medium text-xs tracking-widest uppercase text-oak-light">Composite</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-cream-dark">
                    {[
                      ['Aspect naturel',      '★★★★★', '★★★★☆'],
                      ['Résistance humidité', '★★★☆☆', '★★★★★'],
                      ['Entretien',           'Huilage annuel', 'Nettoyage simple'],
                      ['Durée de vie',        '15–20 ans', '25–30 ans'],
                      ['Glissance mouillée',  'Variable',  'Anti-dérapant'],
                      ['Budget',              '€€',        '€€€'],
                    ].map(([crit, bois, comp]) => (
                      <tr class="bg-white hover:bg-cream-warm transition-colors">
                        <td class="px-5 py-3.5 text-navy font-medium">{crit}</td>
                        <td class="px-5 py-3.5 text-center text-stone">{bois}</td>
                        <td class="px-5 py-3.5 text-center text-navy font-medium">{comp}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>

            <!-- Options -->
            <div class="mt-12 reveal">
              <h3 class="font-serif text-h3 text-navy mb-6">Prestations complémentaires</h3>
              <div class="grid sm:grid-cols-2 gap-4">
                {[
                  { label: 'Claustra et brise-vue',   detail: 'Intimité et esthétique, bois ou composite' },
                  { label: 'Pergola et carport',       detail: 'Structure bois, toile ou polycarbonate' },
                  { label: 'Escalier de terrasse',     detail: 'Sur mesure, en harmonie avec la terrasse' },
                  { label: 'Garde-corps',              detail: 'Bois, inox, verre — selon réglementation' },
                  { label: 'Éclairage intégré',        detail: 'Spots LED encastrés dans la structure' },
                  { label: 'Plancher sur plots',       detail: 'Sans travaux de maçonnerie, idéal en rénovation' },
                ].map(m => (
                  <div class="bg-white border border-cream-dark rounded-sm p-4">
                    <p class="font-sans text-sm font-medium text-navy mb-0.5">{m.label}</p>
                    <p class="font-sans text-xs text-stone">{m.detail}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- Sidebar -->
          <aside class="reveal-left">
            <div class="bg-navy rounded-sm p-7 text-cream sticky top-28">
              <div class="absolute left-0 top-0 bottom-0 w-1 bg-oak rounded-l-sm" aria-hidden="true"></div>
              <p class="font-serif text-xl text-cream mb-1">Un projet de terrasse ?</p>
              <p class="font-sans text-sm text-cream/60 mb-6">Devis gratuit · Finistère · 48h</p>
              <a href="/#contact" class="btn-primary w-full justify-center mb-3 text-sm">Demander un devis</a>
              <a href="tel:+33767426234" class="btn-outline w-full justify-center text-sm">07 67 42 62 34</a>
              <div class="mt-6 pt-6 border-t border-white/10 space-y-2">
                {['Visite gratuite sur site', 'Matériaux certifiés PEFC', 'Fixations inox anti-corrosion', 'Garantie pose et matériaux', 'Tout le Finistère (29)'].map(item => (
                  <div class="flex items-center gap-2.5">
                    <svg class="w-4 h-4 text-oak flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-xs text-cream/70">{item}</span>
                  </div>
                ))}
              </div>
            </div>
            <div class="mt-6 bg-cream-warm border border-cream-dark rounded-sm p-6">
              <p class="font-sans text-xs tracking-widest uppercase text-stone mb-4">Autres services</p>
              <nav class="flex flex-col gap-2">
                {[
                  { href: '/services/cuisine-sur-mesure-finistere/', label: 'Cuisine sur mesure' },
                  { href: '/services/dressing-rangements-sur-mesure/', label: 'Dressing & rangements' },
                  { href: '/services/bardage-exterieur-landivisiau/', label: 'Bardage extérieur' },
                ].map(s => (
                  <a href={s.href} class="font-sans text-sm text-stone hover:text-navy flex items-center gap-2 group transition-colors duration-200">
                    <span class="w-4 h-px bg-oak/30 group-hover:w-6 group-hover:bg-oak transition-all duration-300" aria-hidden="true"></span>
                    {s.label}
                  </a>
                ))}
              </nav>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <!-- ── FAQ ────────────────────────────────────────────────── -->
    <ServiceFAQ serviceLabel="Terrasse bois & composite" items={faq} />

    <!-- CTA FINAL -->
    <section class="section bg-navy relative overflow-hidden">
      <!-- Fond texture bois -->
      <div class="absolute inset-0 bg-grain opacity-20 pointer-events-none" aria-hidden="true"></div>

      <!-- Coins décoratifs -->
      <div class="absolute top-8 left-8 w-12 h-12 border-t border-l border-oak/30 pointer-events-none" aria-hidden="true"></div>
      <div class="absolute top-8 right-8 w-12 h-12 border-t border-r border-oak/30 pointer-events-none" aria-hidden="true"></div>
      <div class="absolute bottom-8 left-8 w-12 h-12 border-b border-l border-oak/30 pointer-events-none" aria-hidden="true"></div>
      <div class="absolute bottom-8 right-8 w-12 h-12 border-b border-r border-oak/30 pointer-events-none" aria-hidden="true"></div>

      <div class="container relative text-center">
        <!-- Ornement centré -->
        <div class="flex items-center justify-center gap-4 mb-8 reveal" aria-hidden="true">
          <div class="h-px w-16 bg-gradient-to-r from-transparent to-oak/50"></div>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--oak)" opacity="0.6">
            <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/>
          </svg>
          <div class="h-px w-16 bg-gradient-to-l from-transparent to-oak/50"></div>
        </div>

        <h2 class="font-serif text-h2 text-cream mb-4 reveal">Profitez de votre jardin<br><em>toute l'année</em></h2>
        <p class="font-sans text-body-lg text-cream/60 max-w-xl mx-auto mb-10 reveal">
          Devis gratuit sur site. Steven intervient dans tout le Finistère.
        </p>
        <div class="flex flex-wrap gap-4 justify-center reveal">
          <a href="/#contact" class="btn-primary px-10 py-4">Demander un devis gratuit</a>
          <a href="tel:+33767426234" class="btn-outline px-10 py-4">07 67 42 62 34</a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
  <CookieBanner />
  <WhatsAppFAB />
</Layout>

<!-- Accordion géré par ServiceFAQ.astro -->
