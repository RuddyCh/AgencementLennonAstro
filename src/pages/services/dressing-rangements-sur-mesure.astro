---
/**
 * /services/dressing-rangements-sur-mesure/
 * Cibles SEO : "dressing sur mesure Finistère", "placard sur mesure Landivisiau",
 *              "rangement sur mesure Brest", "bibliothèque sur mesure Bretagne"
 */
import Layout  from '../../layouts/Layout.astro';
import Navbar  from '../../components/Navbar.astro';
import Footer  from '../../components/Footer.astro';
import CookieBanner from '../../components/CookieBanner.astro';
import WhatsAppFAB   from '../../components/WhatsAppFAB.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import ServiceFAQ  from '../../components/ServiceFAQ.astro';

import serviceData from '../../../content/services/dressing.json';

const serviceJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Dressing et rangements sur mesure en Finistère",
  "description": "Conception et pose de dressings, placards, bibliothèques et rangements sur mesure à Landivisiau et dans tout le Finistère. Agencement Lennon, artisan menuisier.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Agencement Lennon",
    "telephone": "+33767426234",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "11 rue des Cols-Verts",
      "addressLocality": "Landivisiau",
      "postalCode": "29400",
      "addressCountry": "FR"
    }
  },
  "areaServed": [
    { "@type": "City", "name": "Landivisiau" },
    { "@type": "City", "name": "Brest" },
    { "@type": "City", "name": "Morlaix" },
    { "@type": "AdministrativeArea", "name": "Finistère" }
  ]
});

const faq = serviceData.faq ?? [];

const solutions = [
  { title: 'Dressing chambre', desc: 'Penderies, tiroirs, étagères — organisés selon vos habitudes', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
  { title: 'Placard de couloir', desc: 'Optimisation de l\'entrée avec manteaux, chaussures, rangements', icon: 'M4 6h16M4 10h16M4 14h16M4 18h16' },
  { title: 'Bibliothèque sur mesure', desc: 'Du sol au plafond, en niche ou en saillie, avec ou sans portes', icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253' },
  { title: 'Aménagement sous escalier', desc: 'Chaque centimètre optimisé : tiroirs, penderie, cellier', icon: 'M3 10h18M3 14h18m-9-4v8m-7 0h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z' },
  { title: 'Rangement buanderie', desc: 'Meubles hauts, bacs à linge, plan de travail, colonnes', icon: 'M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6zm11-1a1 1 0 00-1 1v6a1 1 0 001 1h2a1 1 0 001-1v-6a1 1 0 00-1-1h-2z' },
  { title: 'Meuble TV et multimédia', desc: 'Niche encastrée, gestion des câbles, éclairage LED intégré', icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z' },
];
---

<Layout
  title="Dressing & Rangements sur mesure Finistère — Landivisiau | Agencement Lennon"
  description="Dressings, placards et bibliothèques sur mesure en Finistère. Artisan menuisier à Landivisiau. Espaces atypiques, sous combles, sous escalier. Devis gratuit."
  canonical="https://www.agencementlennon.fr/services/dressing-rangements-sur-mesure/"
  isHome={false}
>
  <script type="application/ld+json" set:html={serviceJsonLd} slot="head" />
  <Navbar />

  <main id="contenu">

    <!-- HERO -->
    <!-- ── HERO PAGE SERVICE ───────────────────────────────────── -->
    <ServiceHero
      eyebrow="Menuiserie intérieure"
      titleLine1="Dressing & rangements"
      titleLine2="sur mesure en Finistère"
      subtitle={serviceData.heroSubtitle}
      breadcrumb="Dressing & rangements"
    />

    <!-- IMAGES -->
    <div class="bg-cream-warm">
      <div class="container py-0">
        <div class="grid lg:grid-cols-2 gap-0 rounded-sm overflow-hidden shadow-luxury-lg -mt-8 lg:-mt-12 relative z-10">
          <div class="aspect-[4/3] bg-navy/10 min-h-[280px] overflow-hidden">
            {serviceData.photo1 ? (
              <img src={serviceData.photo1} alt={serviceData.photo1Alt} class="w-full h-full object-cover" loading="eager" />
            ) : (
              <div class="w-full h-full flex items-center justify-center p-8">
                <div class="text-center">
                  <svg class="w-12 h-12 text-navy/20 mx-auto mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect width="18" height="18" x="3" y="3" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                  <p class="font-sans text-xs text-navy/30">Photo à ajouter via l'admin Tina<br>Pages Services → Dressing → Photo principale</p>
                </div>
              </div>
            )}
          </div>
          <div class="aspect-[4/3] bg-cream-dark min-h-[280px] overflow-hidden">
            {serviceData.photo2 ? (
              <img src={serviceData.photo2} alt={serviceData.photo2Alt} class="w-full h-full object-cover" loading="lazy" />
            ) : (
              <div class="w-full h-full flex items-center justify-center p-8">
                <div class="text-center">
                  <svg class="w-12 h-12 text-navy/20 mx-auto mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect width="18" height="18" x="3" y="3" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                  <p class="font-sans text-xs text-navy/30">2ème photo à ajouter via l'admin Tina<br>Pages Services → Dressing → Photo secondaire</p>
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>

    <!-- SOLUTIONS GRID -->
    <section class="section bg-cream-warm">
      <div class="container">
        <div class="grid lg:grid-cols-3 gap-16">
          <div class="lg:col-span-2">
            <h2 class="font-serif text-h2 text-navy mb-6 reveal">Nos solutions<br><em>de rangement</em></h2>
            <div class="ornament-line reveal-clip mb-10"></div>

            <div class="grid sm:grid-cols-2 gap-5 stagger-parent mb-12">
              {solutions.map(s => (
                <div class="stagger-child bg-white border border-cream-dark rounded-sm p-6 hover:shadow-luxury hover:-translate-y-0.5 transition-all duration-300">
                  <svg class="w-6 h-6 text-oak mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d={s.icon}/>
                  </svg>
                  <h3 class="font-serif text-lg text-navy mb-1">{s.title}</h3>
                  <p class="font-sans text-sm text-stone leading-relaxed">{s.desc}</p>
                </div>
              ))}
            </div>

            <div class="reveal space-y-5 font-sans text-stone leading-relaxed">
              <h3 class="font-serif text-h3 text-navy">Pourquoi choisir le sur-mesure ?</h3>
              <p>{serviceData.intro1}</p>
              <p>{serviceData.intro2}</p>
              <p>{serviceData.intro3}</p>
            </div>
          </div>

          <aside class="reveal-left">
            <div class="bg-navy rounded-sm p-7 text-cream sticky top-28">
              <div class="absolute left-0 top-0 bottom-0 w-1 bg-oak rounded-l-sm" aria-hidden="true"></div>
              <p class="font-serif text-xl text-cream mb-1">Un projet de rangement ?</p>
              <p class="font-sans text-sm text-cream/60 mb-6">Devis gratuit · Finistère · 48h</p>
              <a href="/#contact" class="btn-primary w-full justify-center mb-3 text-sm">Demander un devis</a>
              <a href="tel:+33767426234" class="btn-outline w-full justify-center text-sm">07 67 42 62 34</a>
              <div class="mt-6 pt-6 border-t border-white/10 space-y-2">
                {['Cotes au millimètre', 'Espaces atypiques acceptés', 'Plan avant fabrication', 'Portes coulissantes ou battantes', 'Tout le Finistère (29)'].map(item => (
                  <div class="flex items-center gap-2.5">
                    <svg class="w-4 h-4 text-oak flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-xs text-cream/70">{item}</span>
                  </div>
                ))}
              </div>
            </div>
            <div class="mt-6 bg-cream-warm border border-cream-dark rounded-sm p-6">
              <p class="font-sans text-xs tracking-widest uppercase text-stone mb-4">Autres services</p>
              <nav class="flex flex-col gap-2">
                {[
                  { href: '/services/cuisine-sur-mesure-finistere/', label: 'Cuisine sur mesure' },
                  { href: '/services/terrasse-bois-composite-finistere/', label: 'Terrasse bois & composite' },
                  { href: '/services/bardage-exterieur-landivisiau/', label: 'Bardage extérieur' },
                ].map(s => (
                  <a href={s.href} class="font-sans text-sm text-stone hover:text-navy flex items-center gap-2 group transition-colors duration-200">
                    <span class="w-4 h-px bg-oak/30 group-hover:w-6 group-hover:bg-oak transition-all duration-300" aria-hidden="true"></span>{s.label}
                  </a>
                ))}
              </nav>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <!-- ── FAQ ────────────────────────────────────────────────── -->
    <ServiceFAQ serviceLabel="Dressing & rangements" items={faq} />

    <section class="section bg-navy relative overflow-hidden">
      <!-- Fond texture bois -->
      <div class="absolute inset-0 bg-grain opacity-20 pointer-events-none" aria-hidden="true"></div>

      <!-- Coins décoratifs -->
      <div class="absolute top-8 left-8 w-12 h-12 border-t border-l border-oak/30 pointer-events-none" aria-hidden="true"></div>
      <div class="absolute top-8 right-8 w-12 h-12 border-t border-r border-oak/30 pointer-events-none" aria-hidden="true"></div>
      <div class="absolute bottom-8 left-8 w-12 h-12 border-b border-l border-oak/30 pointer-events-none" aria-hidden="true"></div>
      <div class="absolute bottom-8 right-8 w-12 h-12 border-b border-r border-oak/30 pointer-events-none" aria-hidden="true"></div>

      <div class="container relative text-center">
        <!-- Ornement centré -->
        <div class="flex items-center justify-center gap-4 mb-8 reveal" aria-hidden="true">
          <div class="h-px w-16 bg-gradient-to-r from-transparent to-oak/50"></div>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--oak)" opacity="0.6">
            <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/>
          </svg>
          <div class="h-px w-16 bg-gradient-to-l from-transparent to-oak/50"></div>
        </div>

        <h2 class="font-serif text-h2 text-cream mb-4 reveal">Un espace optimisé,<br><em>enfin à votre mesure</em></h2>
        <p class="font-sans text-body-lg text-cream/60 max-w-xl mx-auto mb-10 reveal">
          Premier rendez-vous gratuit. Finistère et alentours.
        </p>
        <div class="flex flex-wrap gap-4 justify-center reveal">
          <a href="/#contact" class="btn-primary px-10 py-4">Demander un devis gratuit</a>
          <a href="tel:+33767426234" class="btn-outline px-10 py-4">07 67 42 62 34</a>
        </div>
      </div>
    </section>

  </main>
  <Footer /><CookieBanner />
  <WhatsAppFAB />
</Layout>
<!-- Accordion géré par ServiceFAQ.astro -->
