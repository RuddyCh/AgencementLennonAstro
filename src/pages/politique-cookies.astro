---
/**
 * politique-cookies.astro — Page politique de cookies
 */

import Layout  from '../layouts/Layout.astro';
import Navbar  from '../components/Navbar.astro';
import Footer  from '../components/Footer.astro';
---

<Layout
  title="Politique de cookies | Agencement Lennon — Landivisiau"
  description="Politique de cookies du site Agencement Lennon, menuiserie sur mesure à Landivisiau (Finistère)."
  canonical="https://www.agencementlennon.fr/politique-cookies"
  robots="noindex, follow"
>
  <Navbar />

  <main class="legal-page" id="contenu">
    <div class="container pt-28 pb-20">

      <h1 class="font-serif text-h1 text-navy mb-10 pb-6 border-b border-cream-dark">
        Politique de cookies
      </h1>

      <div class="max-w-prose-xl space-y-10">

        <section>
          <h2 class="font-serif text-xl text-navy mb-4">Qu'est-ce qu'un cookie ?</h2>
          <p class="font-sans text-stone leading-relaxed">
            Un cookie est un petit fichier texte enregistré sur votre appareil lors de la
            consultation de notre site. Il permet de mémoriser des informations pour faciliter
            votre navigation et améliorer l'expérience utilisateur.
          </p>
        </section>

        <section>
          <h2 class="font-serif text-xl text-navy mb-4">Types de cookies utilisés</h2>
          <ul class="space-y-4">
            <li class="font-sans text-stone leading-relaxed pl-4 border-l-2 border-oak/40">
              <strong class="text-navy">Cookies nécessaires :</strong> indispensables au bon
              fonctionnement du site (mémorisation de votre choix de consentement). Ils ne peuvent
              pas être désactivés.
            </li>
            <li class="font-sans text-stone leading-relaxed pl-4 border-l-2 border-oak/40">
              <strong class="text-navy">Cookies de mesure d'audience :</strong> collectent des
              informations anonymes sur la fréquentation (pages consultées, durée de visite).
              Uniquement déposés avec votre accord.
            </li>
            <li class="font-sans text-stone leading-relaxed pl-4 border-l-2 border-oak/40">
              <strong class="text-navy">Cookies tiers :</strong> la carte Google Maps intégrée
              dans notre page contact peut déposer ses propres cookies pour fonctionner correctement.
            </li>
          </ul>
        </section>

        <section>
          <h2 class="font-serif text-xl text-navy mb-4">Gestion des cookies</h2>
          <p class="font-sans text-stone leading-relaxed">
            Lors de votre première visite, un bandeau vous permet d'accepter ou refuser les cookies
            non essentiels. Votre choix est conservé 6 mois. Vous pouvez le modifier à tout moment
            via le lien « Gérer les cookies » en bas de page, ou en configurant votre navigateur.
          </p>
        </section>

        <section>
          <h2 class="font-serif text-xl text-navy mb-4">Vos droits</h2>
          <p class="font-sans text-stone leading-relaxed">
            Conformément au RGPD, vous disposez d'un droit d'accès, de rectification et de
            suppression de vos données. Pour toute question :
            <a href="mailto:contact@agencementlennon.fr" class="text-oak hover:text-oak-dark transition-colors">
              contact@agencementlennon.fr
            </a>
          </p>
        </section>

        <div class="pt-6">
          <a href="/" class="btn-outline-dark text-sm">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="m15 18-6-6 6-6"/>
            </svg>
            Retour à l'accueil
          </a>
        </div>

      </div>
    </div>
  </main>

  <Footer />
</Layout>
