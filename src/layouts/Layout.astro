---
/**
 * Layout.astro — Agencement Lennon
 * Layout principal avec SEO complet, fonts, et métadonnées
 */

export interface Props {
  title?:       string;
  description?: string;
  image?:       string;
  canonical?:   string;
  isHome?:      boolean;
}

const {
  title       = 'Agencement Lennon | Menuiserie sur mesure à Landivisiau – La qualité par passion',
  description = 'Agencement Lennon, menuiserie intérieure & extérieure sur mesure à Landivisiau (29). Cuisines, dressings, parquets, terrasses, bardages. Devis gratuit. La qualité par passion.',
  image       = '/images/wood-bg-blue.jpg',
  canonical   = 'https://www.agencementlennon.fr/',
  isHome      = false,
} = Astro.props;

const siteName = 'Agencement Lennon';
const siteUrl  = 'https://www.agencementlennon.fr';
const ogImage  = `${siteUrl}${image}`;

// JSON-LD Schema.org LocalBusiness — uniquement sur la page d'accueil
const jsonLd = isHome ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "HomeAndConstructionBusiness"],
  "@id": "https://www.agencementlennon.fr/#business",
  "name": "Agencement Lennon",
  "description": "Menuiserie intérieure et extérieure sur mesure à Landivisiau : cuisines, dressings, parquets, terrasses, bardages, pergolas.",
  "slogan": "La qualité par passion",
  "image": ogImage,
  "logo": `${siteUrl}/images/logo-lennon.png`,
  "url": siteUrl,
  "telephone": "+33767426234",
  "email": "contact@agencementlennon.fr",
  "foundingDate": "2021",
  "priceRange": "€€",
  "currenciesAccepted": "EUR",
  "paymentAccepted": "Virement, Chèque, Espèces",
  "openingHoursSpecification": [{
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
    "opens": "08:00",
    "closes": "18:00"
  }],
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "11 rue des Cols-Verts",
    "addressLocality": "Landivisiau",
    "postalCode": "29400",
    "addressRegion": "Bretagne",
    "addressCountry": "FR"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 48.5165,
    "longitude": -4.0626
  },
  "areaServed": [
    {"@type": "City", "name": "Landivisiau"},
    {"@type": "City", "name": "Brest"},
    {"@type": "City", "name": "Morlaix"},
    {"@type": "AdministrativeArea", "name": "Finistère"},
    {"@type": "AdministrativeArea", "name": "Bretagne"}
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Services de menuiserie sur mesure",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Cuisine sur mesure", "description": "Conception et pose de cuisines équipées sur mesure en Finistère" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Terrasse bois & composite", "description": "Pose de terrasses bois et bois composite, résistantes au climat breton" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Bardage extérieur", "description": "Bardage et habillage de façades, extensions" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Dressing & rangements sur mesure", "description": "Dressings, placards et bibliothèques sur mesure" } }
    ]
  },
  "sameAs": ["https://www.facebook.com/AgencementLennon29"]
}) : null;
---
<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
<head>
  <!--
    ⚡ Progressive Enhancement — détection JS en tête de document.
    La classe .js-enabled est ajoutée AVANT tout parsing CSS/JS.
    Sans elle, les éléments animés restent visibles (opacity:1 par défaut).
    Avec elle, le CSS peut les masquer en toute sécurité.
    → Protège contre : GSAP qui plante, JS désactivé, connexion 4G lente.
  -->
  <script is:inline>document.documentElement.classList.add('js-enabled');</script>

  <!--
    ── Scroll vers ancre après navigation inter-pages ──────────────
    Quand on arrive sur /#contact depuis une page service, le navigateur
    tente le scroll AVANT que GSAP ait rendu les éléments visibles.
    Ce script attend que tout soit chargé et re-scroll vers le bon endroit.
  -->
  <script is:inline>
    window.addEventListener('load', function () {
      var hash = window.location.hash;
      if (!hash) return;
      // Petit délai pour laisser GSAP initialiser ses animations
      setTimeout(function () {
        var target = document.querySelector(hash);
        if (!target) return;
        var navHeight = document.querySelector('header')?.offsetHeight || 80;
        var top = target.getBoundingClientRect().top + window.scrollY - navHeight - 16;
        window.scrollTo({ top: top, behavior: 'smooth' });
      }, 120);
    });
  </script>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#0D1F3C" />

  <!-- SEO primaire -->
  <title>{title}</title>
  <meta name="description"   content={description} />
  <meta name="robots"        content="index, follow" />
  <meta name="author"        content="Steven Lennon — Agencement Lennon" />
  <link rel="canonical"      href={canonical} />

  <!-- Géolocalisation -->
  <meta name="geo.region"    content="FR-29" />
  <meta name="geo.placename" content="Landivisiau" />
  <meta name="geo.position"  content="48.5165;-4.0626" />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:site_name"   content={siteName} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImage} />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:url"         content={canonical} />
  <meta property="og:locale"      content="fr_FR" />

  <!-- Twitter Cards -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />

  <!-- Favicon -->
  <link rel="icon" href="/favicon.png" type="image/png" />

  <!-- Préconnexion & préchargement des polices -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500&display=swap"
    rel="stylesheet"
  />

  <!-- Préchargement image hero : géré par fetchpriority="high" sur le composant <Image> -->

  <!-- JSON-LD -->
  {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}

  <!-- GSAP via CDN -->
  <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />
</head>
<body class="bg-cream text-navy overflow-x-hidden pb-[68px] lg:pb-0">

  <!-- Accessibilité : skip link -->
  <a class="skip-link" href="#contenu">Aller au contenu principal</a>

  <slot />

  <!-- GSAP + ScrollTrigger -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

  <!--
    ═══════════════════════════════════════════════════════════════
    LENIS SMOOTH SCROLL (optionnel — décommenter pour activer)
    Nécessite : npm install lenis
    Puis importer dans un script Astro : import Lenis from 'lenis'
    ═══════════════════════════════════════════════════════════════
    Pour l'activer via CDN (sans npm), décommenter ci-dessous :
    <script is:inline src="https://unpkg.com/lenis@1.1.18/dist/lenis.min.js"></script>
    Et dans initAnimations() ci-dessous, décommenter le bloc Lenis.
  -->

  <!-- Curseur personnalisé — élément injecté en JS pour éviter le flash -->
  <script is:inline>
    // ── Curseur personnalisé ─────────────────────────────────────────
    // Créé dynamiquement : pas de flash HTML si JS est désactivé
    (function() {
      // Uniquement sur desktop (pointeur précis)
      if (!window.matchMedia('(pointer: fine)').matches) return;

      const cursor = document.createElement('div');
      cursor.className = 'custom-cursor';
      cursor.setAttribute('aria-hidden', 'true');
      document.body.appendChild(cursor);

      let mouseX = 0, mouseY = 0;
      let curX = 0, curY = 0;
      let animId;

      const lerp = (a, b, n) => (1 - n) * a + n * b;

      const loop = () => {
        curX = lerp(curX, mouseX, 0.14);
        curY = lerp(curY, mouseY, 0.14);
        cursor.style.transform = `translate(${curX}px, ${curY}px) translate(-50%, -50%)`;
        animId = requestAnimationFrame(loop);
      };

      document.addEventListener('mousemove', e => {
        mouseX = e.clientX;
        mouseY = e.clientY;
        cursor.classList.add('cursor-active');
        if (!animId) loop();
      }, { passive: true });

      document.addEventListener('mouseleave', () => {
        cursor.classList.remove('cursor-active');
      });

      // Loupe sur les items de galerie
      document.addEventListener('mouseover', e => {
        const galleryItem = e.target.closest('[data-lightbox]');
        const isLink      = e.target.closest('a, button');
        cursor.classList.toggle('cursor-gallery', !!galleryItem);
        cursor.classList.toggle('cursor-link',    !galleryItem && !!isLink);
      });

      // Activer le masquage du curseur natif
      document.body.classList.add('cursor-ready');
    })();
  </script>

  <!-- Animation principale GSAP — encapsulée dans une fonction pour View Transitions -->
  <script is:inline>
    function initAnimations() {
      if (typeof gsap === 'undefined') return;

      gsap.registerPlugin(ScrollTrigger);

      // ── Respect des préférences utilisateur ──
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // ── Fix hero-reveal : passer de visibility:hidden à visible avant animation ──
      // (évite le flash de contenu non stylé sans bloquer le LCP de l'image)
      if (prefersReducedMotion) {
        document.querySelectorAll('.hero-reveal').forEach(el => {
          el.style.visibility = 'visible';
        });
        return;
      }

      // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
      // LENIS (décommenter si installé via npm ou CDN ci-dessus)
      // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
      // if (typeof Lenis !== 'undefined') {
      //   const lenis = new Lenis({ duration: 1.4, easing: t => Math.min(1, 1.001 - Math.pow(2, -10 * t)) });
      //   lenis.on('scroll', ScrollTrigger.update);
      //   gsap.ticker.add(time => lenis.raf(time * 1000));
      //   gsap.ticker.lagSmoothing(0);
      // }

      // ── .reveal : fade + glisse vers le haut ──
      gsap.utils.toArray('.reveal').forEach(el => {
        gsap.fromTo(el,
          { opacity: 0, y: 50 },
          {
            opacity: 1, y: 0,
            duration: 0.9,
            ease: 'power4.out',
            scrollTrigger: { trigger: el, start: 'top 88%', once: true },
          }
        );
      });

      // ── .reveal-scale : scale + fade ──
      gsap.utils.toArray('.reveal-scale').forEach(el => {
        gsap.fromTo(el,
          { opacity: 0, scale: 0.94 },
          {
            opacity: 1, scale: 1,
            duration: 1.1,
            ease: 'power4.out',
            scrollTrigger: { trigger: el, start: 'top 88%', once: true },
          }
        );
      });

      // ── .reveal-left : glisse depuis la gauche ──
      gsap.utils.toArray('.reveal-left').forEach(el => {
        gsap.fromTo(el,
          { opacity: 0, x: -60 },
          {
            opacity: 1, x: 0,
            duration: 1.0,
            ease: 'power4.out',
            scrollTrigger: { trigger: el, start: 'top 88%', once: true },
          }
        );
      });

      // ── .reveal-clip : clip-path de droite à gauche ──
      gsap.utils.toArray('.reveal-clip').forEach(el => {
        gsap.fromTo(el,
          { clipPath: 'inset(0 100% 0 0)' },
          {
            clipPath: 'inset(0 0% 0 0)',
            duration: 1.2,
            ease: 'power4.out',
            scrollTrigger: { trigger: el, start: 'top 90%', once: true },
          }
        );
      });

      // ── Staggered cards ──
      gsap.utils.toArray('.stagger-parent').forEach(parent => {
        const children = parent.querySelectorAll('.stagger-child');
        if (!children.length) return;
        gsap.fromTo(children,
          { opacity: 0, y: 40 },
          {
            opacity: 1, y: 0,
            duration: 0.8,
            stagger: 0.15,
            ease: 'power4.out',
            scrollTrigger: { trigger: parent, start: 'top 82%', once: true },
          }
        );
      });

      // ── Parallaxe léger sur le hero ──
      const heroBg = document.querySelector('.hero-parallax-bg');
      if (heroBg) {
        gsap.to(heroBg, {
          yPercent: 25,
          ease: 'none',
          scrollTrigger: {
            trigger: '.hero',
            start: 'top top',
            end: 'bottom top',
            scrub: 1.5,
          },
        });
      }

      // ── Parallaxe subtil sur les images de la galerie ──
      // Effet de profondeur : l'image "avance" légèrement dans son cadre au scroll
      gsap.utils.toArray('.gallery-item').forEach(item => {
        const img = item.querySelector('img');
        if (!img) return;
        gsap.fromTo(img,
          { yPercent: -5 },
          {
            yPercent: 5,
            ease: 'none',
            scrollTrigger: {
              trigger: item,
              start: 'top bottom',
              end: 'bottom top',
              scrub: 1.2,
            },
          }
        );
      });

      // ── Zoom scale "entrée en scène" sur les images de contenu ──
      // Images de la section About + toute image marquée .img-reveal-zoom
      // Scale de 1.08 → 1.0 quand l'image entre dans le viewport : effet "focus"
      gsap.utils.toArray('.about-image-main, .img-reveal-zoom').forEach(img => {
        gsap.fromTo(img,
          { scale: 1.08, opacity: 0 },
          {
            scale: 1,
            opacity: 1,
            duration: 1.4,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: img,
              start: 'top 85%',
              once: true,
            },
          }
        );
      });

      // ── Hero : révélation séquentielle — visibility → visible avant fromTo ──
      const heroEls = document.querySelectorAll('.hero-reveal');
      if (heroEls.length) {
        // D'abord rendre visibles (retirer le visibility:hidden du CSS)
        heroEls.forEach(el => { el.style.visibility = 'visible'; });
        gsap.fromTo(heroEls,
          { opacity: 0, y: 40 },
          {
            opacity: 1, y: 0,
            duration: 1,
            stagger: 0.18,
            ease: 'power4.out',
            delay: 0.2,
          }
        );
      }

      // ── Compteurs animés ──
      document.querySelectorAll('[data-count]').forEach(el => {
        const target  = parseInt(el.getAttribute('data-count'), 10);
        const suffix  = el.getAttribute('data-suffix') || '';
        const counter = { val: 0 };
        ScrollTrigger.create({
          trigger: el,
          start: 'top 85%',
          once: true,
          onEnter: () => {
            gsap.to(counter, {
              val: target,
              duration: 1.6,
              ease: 'power2.out',
              onUpdate: () => {
                el.textContent = Math.round(counter.val) + suffix;
              },
            });
          },
        });
      });

      // ── Titre lettre par lettre (.split-title) ──
      document.querySelectorAll('.split-title').forEach(el => {
        const text = el.textContent.trim();
        el.innerHTML = text.split('').map(char =>
          char === ' '
            ? '<span style="display:inline-block;width:0.3em"></span>'
            : `<span class="split-char" style="display:inline-block;opacity:0;transform:translateY(110%)">${char}</span>`
        ).join('');
        ScrollTrigger.create({
          trigger: el,
          start: 'top 90%',
          once: true,
          onEnter: () => {
            gsap.to(el.querySelectorAll('.split-char'), {
              opacity: 1, y: 0,
              duration: 0.6,
              stagger: 0.03,
              ease: 'power3.out',
            });
          },
        });
      });
    }

    // ── Lancement ─────────────────────────────────────────────────
    // Compatible Astro View Transitions : écoute astro:page-load
    // si View Transitions est activé, sinon DOMContentLoaded suffit.
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAnimations);
    } else {
      initAnimations();
    }
    // View Transitions ready (à activer quand @astrojs/transitions sera intégré)
    document.addEventListener('astro:page-load', () => {
      ScrollTrigger.getAll().forEach(t => t.kill());
      initAnimations();
    });
  </script>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
